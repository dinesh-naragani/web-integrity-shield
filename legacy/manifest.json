{
  "manifest_version": 3,
  "name": "Web Integrity Shield",
  "version": "1.0.0",
  "description": "Checks the current tab URL against the Web Integrity Shield backend.",
  "permissions": [
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_title": "Web Integrity Shield",
    "default_popup": "popup.html"
  }
}
