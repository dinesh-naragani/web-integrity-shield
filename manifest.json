{
  "manifest_version": 3,
  "name": "Web Integrity Shield",
  "version": "1.0.0",
  "description": "Checks the current tab URL against the Web Integrity Shield backend.",
  "permissions": [
    "tabs",
    "activeTab"
  ],
  "host_permissions": [
    "http://localhost:8080/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Web Integrity Shield",
    "default_popup": "popup.html"
  }
}
